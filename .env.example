# --- App ---
NODE_ENV=development
PORT=3000
# Public base URL (used to build station join links + QR codes)
PUBLIC_BASE_URL=http://localhost:3000

# --- Auth ---
# Secret for signing admin JWT cookies. CHANGE IN PROD (openssl rand -hex 32).
JWT_SECRET=dev-insecure-change-me
# Cookie secure flag (true behind TLS / Cloudflare)
COOKIE_SECURE=false

# --- Database ---
# Used by the server and by docker-compose postgres service.
POSTGRES_USER=funk
POSTGRES_PASSWORD=funk
POSTGRES_DB=funkparcours
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full URL (server prefers this if set)
DATABASE_URL=postgres://funk:funk@localhost:5432/funkparcours

# --- Superadmin (operator panel at /super, sees ALL games) ---
# Disabled unless SUPERADMIN_PASSWORD is set (no insecure default access).
SUPERADMIN_USER=superadmin
SUPERADMIN_PASSWORD=

# --- Misc ---
# Rate limit window / max (per IP)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
# Days until an expired game is cleaned up (0 = never auto-expire on create)
DEFAULT_EXPIRY_DAYS=30
