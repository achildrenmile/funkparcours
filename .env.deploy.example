# Config for deploy.sh — copy to .env.deploy and adjust. NOT committed.
HOST=<deploy-host>
USER=<deploy-user>
REMOTE_DIR=<remote-dir>
COMPOSE_FILE=docker-compose.prod.yml
# Git branch deployed
BRANCH=main
# Internal port the app binds on the host (cloudflared targets this)
HEALTH_URL=http://127.0.0.1:3000/healthz
